(extern constructor fadd64 fadd64)
(decl fsub64 (Value Value) Value)
(extern constructor fsub64 fsub64)
(decl fmul64 (Value Value) Value)
(extern constructor fmul64 fmul64)
(decl fdiv64 (Value Value) Value)
(extern constructor fdiv64 fdiv64)

;; Float unary constructors (f32)
(decl fabs32 (Value) Value)
