;; Partial-width memory store constructors
(decl i32_store8 (Value Value u32 u32 u32) Value)
(extern constructor i32_store8 i32_store8)

(decl i32_store16 (Value Value u32 u32 u32) Value)
(extern constructor i32_store16 i32_store16)

(decl i64_store8 (Value Value u32 u32 u32) Value)
